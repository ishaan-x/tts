   "source": "import gradio as gr\nimport threading\n\ndef run_generation(file_obj, text_paste, voice_choice, preset_name, custom_style, speed,\n                   norm_mode, para_pause, chap_pause, do_mp3, do_chapters, do_resume,\n                   sample_only=False, progress=gr.Progress()):\n    clear_stop()\n    vs = custom_style.strip() if preset_name == \"Custom\" else VOICE_PRESETS.get(preset_name, \"\")\n    vn = voice_choice.split(\" (\")[0]\n    log = []\n    \n    def emit(s=\"\", a=\"\", aud=None, wav=None, mp3=None, zipf=None, cmd=\"\"):\n        if a:\n            log.append(a)\n        return s, \"\\n\".join(log[-30:]), aud, wav, mp3, zipf, cmd\n        \n    def pbar(pct, lbl=\"\"):\n        return f'<div style=\"font-family:system-ui;padding:16px;background:#fff;border:1px solid #E5E7EB;border-radius:12px\"><div style=\"font-size:36px;font-weight:800;color:#6366F1;text-align:center\">{pct:.0f}%</div><div style=\"background:#E5E7EB;border-radius:8px;height:16px;overflow:hidden;margin:10px 0\"><div style=\"width:{pct:.0f}%;height:100%;
